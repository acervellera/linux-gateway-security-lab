#!/usr/sbin/nft -f

# Linux Gateway Security Lab
# Ruleset didattico per la VM Kali.
#
# PRIMA DI CARICARLO:
# 1. creare uno snapshot della VM;
# 2. verificare che la WAN sia eth0;
# 3. verificare che la LAN sia eth1;
# 4. verificare che la LAN sia 10.10.10.0/24;
# 5. mantenere aperta la console virt-manager.
#
# Questo file non modifica il ruleset finché non viene caricato esplicitamente:
#   sudo nft -f configs/nftables/gateway.nft.example
#
# Per il rollback mirato:
#   sudo nft delete table inet gateway_filter
#   sudo nft delete table ip gateway_nat

# -----------------------------------------------------------------------------
# FILTRO DEL TRAFFICO INOLTRATO
# -----------------------------------------------------------------------------

table inet gateway_filter {
    chain forward {
        # La chain viene collegata al percorso dei pacchetti che attraversano
        # la macchina. Non controlla il traffico destinato a Kali stessa.
        type filter hook forward priority filter;

        # Tutto ciò che non è permesso esplicitamente viene scartato.
        policy drop;

        # Scarta pacchetti che il connection tracking considera non validi.
        ct state invalid counter drop

        # Permette le risposte a connessioni già autorizzate e il traffico
        # correlato. Questa regola consente il ritorno WAN -> LAN senza aprire
        # indiscriminatamente nuove connessioni dalla WAN.
        ct state established,related counter accept

        # Permette ai client della LAN di iniziare connessioni verso la WAN.
        # iifname  = interfaccia di ingresso
        # oifname  = interfaccia di uscita
        # ip saddr = rete sorgente autorizzata
        iifname "eth1" oifname "eth0" ip saddr 10.10.10.0/24 counter accept
    }
}

# -----------------------------------------------------------------------------
# NAT IPV4
# -----------------------------------------------------------------------------

table ip gateway_nat {
    chain postrouting {
        # postrouting viene eseguito dopo la decisione di routing e prima
        # dell'uscita del pacchetto.
        type nat hook postrouting priority srcnat;
        policy accept;

        # Sostituisce la sorgente privata dei client con l'indirizzo corrente
        # della WAN. Il limite sulla subnet evita di tradurre traffico estraneo.
        oifname "eth0" ip saddr 10.10.10.0/24 counter masquerade
    }
}
